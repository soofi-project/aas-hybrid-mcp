# Qwen3.5-122B-A10B-Instruct-FP8 (MoE, ~10B active) — lokal H200
# LiteLLM-Alias "qwen35-122b" muss auf dem H200 konfiguriert sein:
#   model_name: qwen35-122b  →  litellm_params.model: openai/Qwen/Qwen3.5-122B-A10B-Instruct-FP8
# Hinweis: ~122GB FP8 — H200 (141GB HBM3e) ist knapp, kein weiterer Dienst beim Laden.
LLM_MODEL=qwen35-122b
QUERY_REWRITE_MODEL=qwen35-122b
