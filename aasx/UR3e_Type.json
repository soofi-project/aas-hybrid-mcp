  "conceptDescriptions": [
    {
      "idShort": "Handling",
      "displayName": [
        {
          "language": "en",
          "text": "Handling"
        },
        {
          "language": "de",
          "text": "Handhabung"
        }
      ],
      "description": [
        {
          "language": "en",
          "text": "Capability of an asset to grasp, move and position workpieces or components — including pick-and-place tasks. Typically realized by robot arms (industrial robots, cobots) with a suitable end effector."
        },
        {
          "language": "de",
          "text": "Capability eines Assets, Werkstücke oder Bauteile zu greifen, zu bewegen und zu positionieren — einschließlich Pick-and-Place-Aufgaben. Typische Realisierung durch Roboterarme (Industrieroboter, Cobots) mit geeignetem Endeffektor."
        }
      ],
      "id": "https://aas-hybrid-mcp.dfki.de/capability/Handling",
