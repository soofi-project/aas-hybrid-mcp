                "language": "en",
                "text": "HANDLING"
              }
            ],
            "definition": [
              {
                "language": "de",
                "text": "Greifen, Bewegen und Positionieren von Werkstücken — analog zur Handhabungsfunktion ‚Handhaben' nach VDI 2860."
              },
              {
                "language": "en",
                "text": "Grasping, moving and positioning of workpieces — analogous to the handling function ‘Handhaben' (handle) per VDI 2860."
