# Benchmark A — Neo4j Ingestion v1 vs v2
#
# Usage: docker compose -f docker-compose.bench.yml --env-file .env.bench --profile <v1|v2> up

# Kafka Connect Neo4j Plugin versions
AKHQ_VERSION=0.25.1

NEO4J_V2_TAG=7.9.1-2.1.3

# Infrastructure versions (must match main .env)
KAFKA_VERSION=7.9.1
BASYX_V3_VERSION=2.0.0-milestone-10
MONGODB_VERSION=8.0.9
MONGODB_URI=mongodb://mongoAdmin:mongoPassword@mongo:27017
