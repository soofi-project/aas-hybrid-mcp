{
  "name": "Kafka2Neo4jConnector",
  "config": {
    "connector.class": "de.dfki.cos.aas2graph.kafka.Neo4jBoltSinkConnector",

    "tasks.max": "1",
    "executor.threads": "1",

    "consumer.override.max.poll.records": "500",
    "consumer.override.max.poll.interval.ms": "300000",
    "consumer.override.fetch.min.bytes": "20971520",
    "consumer.override.fetch.max.wait.ms": "500",
    "consumer.override.max.partition.fetch.bytes": "20971520",
    "offset.flush.timeout.ms": "15000",

    "topics": "aas-events,submodel-events",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter.schemas.enable": "false",

    "errors.tolerance": "none",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true",

    "aas.repo.url": "${env:BASYX_AAS_REPO_URL}",
    "sm.repo.url": "${env:BASYX_AAS_REPO_URL}",

    "neo4j.uri": "${env:NEO4J_URI}",
    "neo4j.user": "${env:NEO4J_USER}",
    "neo4j.password": "${env:NEO4J_PASSWORD}",
    "neo4j.max.pool.size": "${env:NEO4J_MAX_POOL_SIZE}",
    "neo4j.connection.timeout.seconds": "${env:NEO4J_CONNECTION_TIMEOUT_SECONDS}"
  }
}
