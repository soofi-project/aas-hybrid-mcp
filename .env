# BaSyx — separate endpoints allow AAS repo and submodel repo to run independently
AAS_REPO_URL=http://aas-environment:8081
SUBMODEL_REPO_URL=http://aas-environment:8081

# BaSyx & Kafka Versions
BASYX_V3_VERSION=2.0.0-milestone-10
KAFKA_VERSION=7.9.1
RAG_CONNECT_VERSION=0.0.4
NEO4J_KAFKA_CONNECT_VERSION=7.9.1-2.1.2
AKHQ_VERSION=0.25.1
AAS_WEBUI_VERSION=v2-260309
WEAVIATE_VERSION=1.34.15

# MongoDB
MONGODB_VERSION=8.0.9
MONGODB_URI=mongodb://mongoAdmin:mongoPassword@mongo:27017

# Secrets (outside repo)
SECRETS_PATH=~/.env.secrets

# MCP
MCPINSPECTOR_VERSION=0.18.0
MCP_AUTH_TOKEN=dev-stack-token-12345

# Open WebUI
OPEN_WEBUI_VERSION=0.9.2
OPEN_WEBUI_EMAIL=admin@aas-hybrid.mcp
OPEN_WEBUI_PASSWORD=admin

# ----------------------------------------------------------------------------
# Default runtime config — shared across embedding-service,
# submodel-templates-sync, aas-hybrid-mcp, and aas-agent. Override via
# .env.vllm + docker-compose.vllm.yml when using the H200 backend.
# ----------------------------------------------------------------------------

# Embedding model in provider:model format
# Examples:
#   openai:text-embedding-3-small
#   ollama:nomic-embed-text
#   google_genai:text-embedding-004
#   voyageai:voyage-3
# Embedding model in provider:model format.
# The Weaviate collection name is auto-expanded to {WEAVIATE_COLLECTION}_{model}.
# e.g. WEAVIATE_COLLECTION=aas_documents + EMBEDDING_MODEL=openai:text-embedding-3-small
#   → Weaviate collection: aas_documents_text-embedding-3-small
# Changing EMBEDDING_MODEL creates a new collection; old one is kept (no migration needed).
EMBEDDING_MODEL=openai:text-embedding-3-small

# Ollama (local, no API key needed)
OLLAMA_HOST=http://host.docker.internal:11434

# PDF chunking
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=100

# HTTP download timeout in seconds
DOWNLOAD_TIMEOUT=30

# Error handling: "abort" = fail task on error, "skip" = log and continue
ON_PROCESSING_ERROR=abort

# Reranker — disabled by default; .env.vllm flips this to vllm with a real URL
RERANKER_MODE=distance

# Chat LLM — defaults to OpenAI-hosted; .env.vllm overrides for H200/vLLM.
# The API key is OPENAI_API_KEY from ${SECRETS_PATH}; ChatOpenAI in the agent
# reads it directly from the container env, no separate LLM_API_KEY needed.
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4-mini

# Auto-inject MCP resources into the agent system message at startup.
# When false, the agent must fetch the same content on demand via tool
# calls (`get_manual_page`, schema lookup). Useful for comparing
# prompted-context vs. tool-driven retrieval in demos / ablations.
AGENT_INJECT_MANUAL=true
AGENT_INJECT_SCHEMA=true


AGENT_VARIANT=react_validating