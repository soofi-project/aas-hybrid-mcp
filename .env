KAFKA_VERSION=7.9.1
RAG_CONNECT_VERSION=0.0.4
NEO4J_KAFKA_CONNECT_VERSION=7.9.1-1.0.0
AKHQ_VERSION=0.25.1
AAS_WEBUI_VERSION=v2-250417
WEAVIATE_VERSION=1.34.15

# MongoDB
MONGODB_VERSION=8.0.9
MONGODB_URI=mongodb://mongoAdmin:mongoPassword@mongo:27017

# Embedding Service: "fast" (pymupdf4llm, ~50 MB) or "precise" (docling, ~3 GB)
