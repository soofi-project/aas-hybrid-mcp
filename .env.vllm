# vLLM / H200 overrides — applied via docker-compose.vllm.yml when
# `./up.sh --vllm` is used. Same keys as .env, different values.

# Embedding via OpenAI-compatible endpoint on the H200
EMBEDDING_MODEL=openai:qwen3-embedding-8b
OPENAI_BASE_URL=http://10.2.10.33:4000/v1

# Reranker via vLLM (Cohere-compatible /rerank endpoint)
RERANKER_MODE=vllm
RERANKER_URL=http://10.2.10.33:8003
RERANKER_CANDIDATE_LIMIT=20

# Chat LLM via vLLM (OpenAI-compatible)
LLM_BASE_URL=http://10.2.10.33:4000/v1
LLM_MODEL=soofi-nano-30b

# vLLM doesn't validate the API key — overrides the real OpenAI key from
# ${SECRETS_PATH} so the agent and embedding-service don't accidentally
# leak the production key when talking to the H200.
OPENAI_API_KEY=dummy

# Disable thinking mode by default for Qwen on vLLM — system prompt handling
# is broken when thinking is active (the chat template ignores system messages
# and the model falls back to generic greetings).
AGENT_DEFAULT_THINKING=false


AGENT_RECURSION_LIMIT=100

# Query Rewriter via vLLM
QUERY_REWRITE_MODE=on
QUERY_REWRITE_URL=http://10.2.10.33:4000/v1
QUERY_REWRITE_MODEL=qwen36-27b
QUERY_REWRITE_TIMEOUT=30
