# Copy to ~/.env.secrets and fill in your keys:
#   cp .env.secrets.example ~/.env.secrets
#
# Docker Compose loads this file for every service via ${SECRETS_PATH}
# (default ~/.env.secrets, see SECRETS_PATH in .env). Never commit real keys.

# Primary OpenAI-compatible API key — used by the agent, embedding service and
# the LLM judge. With ./up.sh --vllm this is overridden to a dummy value by
# .env.vllm, so a placeholder is fine for a pure-vLLM/H200 setup.
OPENAI_API_KEY=sk-...

# Cortecs API key — only needed for the qwen35-397b eval model
# (./eval-model.sh qwen35-397b) and the LLM judge (tests/agent-tests/judge.sh).
# Leave empty if you don't use Cortecs.
CORTECSAI_API_KEY=
